{
  "name": "Company",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "Firmenname"
    },
    "branche": {
      "type": "string",
      "title": "Branche"
    },
    "adresse": {
      "type": "string",
      "title": "Adresse"
    },
    "plz": {
      "type": "string",
      "title": "PLZ"
    },
    "ort": {
      "type": "string",
      "title": "Ort"
    },
    "telefon": {
      "type": "string",
      "title": "Telefonnummer"
    },
    "email": {
      "type": "string",
      "title": "E-Mail"
    },
    "website": {
      "type": "string",
      "title": "Website"
    },
    "ansprechpartner": {
      "type": "string",
      "title": "Ansprechpartner"
    },
    "latitude": {
      "type": "number",
      "title": "Latitude"
    },
    "longitude": {
      "type": "number",
      "title": "Longitude"
    },
    "entfernung_km": {
      "type": "number",
      "title": "Entfernung (km)"
    },
    "status": {
      "type": "string",
      "title": "Status",
      "enum": [
        "Neu",
        "Kontakt",
        "R\u00fcckruf",
        "Termin",
        "Angebot",
        "Gewonnen",
        "Verloren"
      ],
      "default": "Neu"
    },
    "notizen": {
      "type": "string",
      "title": "Notizen"
    },
    "aktueller_dienstleister": {
      "type": "string",
      "title": "Aktueller Dienstleister (Konkurrenz)"
    },
    "assigned_to": {
      "type": "string",
      "title": "Zugewiesen an"
    },
    "weekly_batch_id": {
      "type": "string",
      "title": "Wochen-Batch ID"
    },
    "is_blacklisted": {
      "type": "boolean",
      "title": "Blacklisted",
      "default": false
    },
    "is_hot": {
      "type": "boolean",
      "title": "Hei\u00dfer Lead",
      "default": false
    },
    "priority_score": {
      "type": "number",
      "title": "Priorit\u00e4tswert",
      "default": 0
    },
    "last_contact_date": {
      "type": "string",
      "format": "date-time",
      "title": "Letzter Kontakt"
    },
    "quelle": {
      "type": "string",
      "title": "Quelle",
      "enum": [
        "Google Places API",
        "CSV Import",
        "Manuell",
        "API"
      ],
      "default": "Manuell"
    }
  },
  "required": [
    "name"
  ]
}