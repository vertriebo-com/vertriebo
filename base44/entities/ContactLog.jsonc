{
  "name": "ContactLog",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "title": "Organisation ID"
    },
    "company_id": {
      "type": "string",
      "title": "Firma ID"
    },
    "typ": {
      "type": "string",
      "title": "Kontaktart",
      "enum": [
        "Anruf",
        "E-Mail",
        "Besuch",
        "Termin",
        "Angebot",
        "Sonstiges"
      ]
    },
    "notiz": {
      "type": "string",
      "title": "Notiz"
    },
    "ergebnis": {
      "type": "string",
      "title": "Ergebnis",
      "enum": [
        "Erreicht",
        "Nicht erreicht",
        "R\u00fcckruf vereinbart",
        "Termin vereinbart",
        "Angebot gesendet",
        "Abgeschlossen",
        "Kein Interesse",
        "Manuell vorbereitet/gesendet"
      ]
    },
    "naechster_schritt": {
      "type": "string",
      "title": "N\u00e4chster Schritt"
    },
    "rueckruf_datum": {
      "type": "string",
      "format": "date-time",
      "title": "R\u00fcckruf am"
    },
    "kontakt_person": {
      "type": "string",
      "title": "Kontaktperson"
    },
    "user_email": {
      "type": "string",
      "title": "Vertriebler"
    },
    "betreff": {
      "type": "string",
      "title": "E-Mail Betreff"
    },
    "sending_mode": {
      "type": "string",
      "title": "Versandmodus",
      "enum": [
        "manual_email_client",
        "brevo",
        "smtp"
      ]
    },
    "is_manual": {
      "type": "boolean",
      "title": "Manuell versendet",
      "default": false
    },
    "is_test_email": {
      "type": "boolean",
      "title": "Test-E-Mail",
      "default": false
    }
  },
  "required": [
    "company_id",
    "typ",
    "ergebnis",
    "naechster_schritt"
  ]
}