{
  "name": "Plan",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "Planname"
    },
    "plan_type": {
      "type": "string",
      "title": "Plan-Typ",
      "enum": [
        "standard",
        "agency"
      ],
      "default": "standard"
    },
    "stripe_price_id": {
      "type": "string",
      "title": "Stripe Price ID"
    },
    "stripe_product_id": {
      "type": "string",
      "title": "Stripe Product ID"
    },
    "price_monthly": {
      "type": "number",
      "title": "Preis/Monat (Cent)"
    },
    "max_users": {
      "type": "number",
      "title": "Max. Benutzer (-1 = unbegrenzt)",
      "default": 3
    },
    "max_leads_per_month": {
      "type": "number",
      "title": "Max. gespeicherte Kontakte (-1 = unbegrenzt)",
      "default": 300
    },
    "max_ai_scorings_per_month": {
      "type": "number",
      "title": "Max. KI-Aktionen/Monat",
      "default": 50
    },
    "max_emails_per_month": {
      "type": "number",
      "title": "Max. E-Mails/Monat",
      "default": 500
    },
    "max_lead_generations_per_month": {
      "type": "number",
      "title": "Max. Recherche-Credits/Monat",
      "default": -1
    },
    "supports_suborganizations": {
      "type": "boolean",
      "title": "Unterst\u00fctzt Unterorganisationen",
      "default": false
    },
    "max_suborganizations": {
      "type": "number",
      "title": "Max. Unterorganisationen (-1 = unbegrenzt)",
      "default": 0
    },
    "has_advanced_reports": {
      "type": "boolean",
      "title": "Erweiterte Reports",
      "default": false
    },
    "has_custom_email_templates": {
      "type": "boolean",
      "title": "Eigene E-Mail-Vorlagen",
      "default": false
    },
    "is_active": {
      "type": "boolean",
      "title": "Plan buchbar",
      "default": true
    },
    "sort_order": {
      "type": "number",
      "title": "Reihenfolge",
      "default": 1
    },
    "cost_per_ai_action_cent": {
      "type": "number",
      "title": "Kosten pro KI-Aktion (Cent, intern)",
      "default": 0
    },
    "cost_per_lead_generation_cent": {
      "type": "number",
      "title": "Kosten pro Recherche-Credit (Cent, intern)",
      "default": 0
    },
    "cost_per_email_cent": {
      "type": "number",
      "title": "Kosten pro E-Mail (Cent, intern)",
      "default": 0
    },
    "cost_per_google_places_request_cent": {
      "type": "number",
      "title": "Kosten pro Google Places API Request (Cent, intern)",
      "default": 0
    },
    "estimated_cost_per_month_cent": {
      "type": "number",
      "title": "Gesch\u00e4tzte externe Kosten/Monat (Cent, intern)",
      "default": 0
    }
  },
  "required": [
    "name"
  ]
}