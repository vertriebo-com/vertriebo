{
  "name": "TaxonomyEntry",
  "type": "object",
  "properties": {
    "industry_id": {
      "type": "string",
      "title": "Branchen-ID (kanonisch)",
      "description": "Eindeutiger Bezeichner z.B. gebaeudereinigung"
    },
    "label": {
      "type": "string",
      "title": "Anzeigename"
    },
    "version": {
      "type": "string",
      "title": "Version dieses Eintrags"
    },
    "is_active": {
      "type": "boolean",
      "title": "Aktiv",
      "default": true
    },
    "sort_order": {
      "type": "number",
      "title": "Reihenfolge in der UI",
      "default": 99
    },
    "status": {
      "type": "string",
      "title": "Qualit\u00e4tsstatus",
      "enum": [
        "production_ready",
        "draft",
        "needs_review",
        "deprecated"
      ],
      "default": "production_ready"
    },
    "profile_group": {
      "type": "string",
      "title": "Profilgruppe (z.B. Handwerk & Bau)"
    },
    "aliases": {
      "type": "string",
      "title": "Aliase (JSON-Array)"
    },
    "own_services": {
      "type": "string",
      "title": "Eigene Dienstleistungen (JSON-Array)"
    },
    "target_customer_types": {
      "type": "string",
      "title": "Zielkundentypen (JSON-Array)"
    },
    "excluded_customer_types": {
      "type": "string",
      "title": "Ausgeschlossene Typen (JSON-Array)"
    },
    "searchable_business_categories": {
      "type": "string",
      "title": "Google-Suchkategorien (JSON-Array)"
    },
    "search_keyword_variants": {
      "type": "string",
      "title": "Suchbegriff-Varianten (JSON-Objekt)"
    },
    "negative_keywords": {
      "type": "string",
      "title": "Negative Keywords (JSON-Array)"
    },
    "bad_fit_signals": {
      "type": "string",
      "title": "Bad-Fit-Signale (JSON-Array)"
    },
    "bad_fit_signal_weights": {
      "type": "string",
      "title": "Bad-Fit-Signal-Gewichte (JSON-Objekt) \u2014 v6"
    },
    "scoring_signals": {
      "type": "string",
      "title": "Scoring-Signale (JSON-Array)"
    },
    "scoring_signal_weights": {
      "type": "string",
      "title": "Scoring-Signal-Gewichte (JSON-Objekt) \u2014 v6"
    },
    "query_priority": {
      "type": "string",
      "title": "Query-Priorit\u00e4t (JSON-Array)"
    },
    "search_strategy": {
      "type": "string",
      "title": "Such-Strategie \u2014 v6",
      "enum": [
        "target_customer_search",
        "provider_search",
        "mixed",
        "registry_enrichment_recommended",
        "website_signal_required"
      ],
      "default": "target_customer_search"
    },
    "place_type_confidence": {
      "type": "string",
      "title": "Place-Type-Konfidenz \u2014 v6",
      "enum": [
        "high",
        "medium",
        "low"
      ],
      "default": "medium"
    },
    "profile_quality_score": {
      "type": "number",
      "title": "Qualit\u00e4tsscore (0\u2013100)"
    },
    "profile_quality_notes": {
      "type": "string",
      "title": "Qualit\u00e4ts-Notizen (Review)"
    },
    "reviewed_at": {
      "type": "string",
      "title": "Gepr\u00fcft am (YYYY-MM-DD)"
    },
    "reviewed_by": {
      "type": "string",
      "title": "Gepr\u00fcft von"
    },
    "ideal_customer_profiles": {
      "type": "string",
      "title": "Ideale Kundenprofile (JSON-Array, nur f\u00fcr KI/Scoring)"
    },
    "google_place_types": {
      "type": "string",
      "title": "Google Place Types (JSON-Array)"
    },
    "content_hash": {
      "type": "string",
      "title": "Hash des Inhalts (zur Sync-Validierung)"
    },
    "last_updated_by": {
      "type": "string",
      "title": "Zuletzt ge\u00e4ndert von (E-Mail)"
    }
  },
  "required": [
    "industry_id",
    "label"
  ]
}