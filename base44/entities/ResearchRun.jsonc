{
  "name": "ResearchRun",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "title": "Organisation ID"
    },
    "status": {
      "type": "string",
      "title": "Status",
      "enum": [
        "queued",
        "running",
        "partial",
        "completed",
        "failed"
      ],
      "default": "queued"
    },
    "run_type": {
      "type": "string",
      "title": "Lauftyp",
      "enum": [
        "new_leads",
        "duplicate_only",
        "no_match",
        "zero_result"
      ]
    },
    "requested_target": {
      "type": "number",
      "title": "Angeforderte Anzahl",
      "default": 25
    },
    "leads_saved": {
      "type": "number",
      "title": "Gespeicherte neue Leads",
      "default": 0
    },
    "duplicates_skipped": {
      "type": "number",
      "title": "\u00dcbersprungene Dubletten",
      "default": 0
    },
    "no_match_count": {
      "type": "number",
      "title": "Unpassende Treffer",
      "default": 0
    },
    "outside_radius_count": {
      "type": "number",
      "title": "Au\u00dferhalb Suchgebiet",
      "default": 0
    },
    "raw_hits": {
      "type": "number",
      "title": "Gepr\u00fcfte Firmenprofile (Roh)",
      "default": 0
    },
    "progress_percent": {
      "type": "number",
      "title": "Fortschritt (%)",
      "default": 0
    },
    "current_step": {
      "type": "string",
      "title": "Aktueller Schritt"
    },
    "batch_index": {
      "type": "number",
      "title": "Aktueller Batch-Index",
      "default": 0
    },
    "total_batches": {
      "type": "number",
      "title": "Gesamtanzahl Batches",
      "default": 0
    },
    "seen_place_ids": {
      "type": "string",
      "title": "Bereits gesehene Place-IDs (JSON)"
    },
    "search_plan_json": {
      "type": "string",
      "title": "Suchplan (JSON)"
    },
    "search_center_city": {
      "type": "string",
      "title": "Suchzentrum Stadt"
    },
    "search_radius_km": {
      "type": "number",
      "title": "Suchradius (km)"
    },
    "target_customer_types": {
      "type": "string",
      "title": "Genutzte Zielkunden (komma-getrennt)"
    },
    "excluded_customer_types": {
      "type": "string",
      "title": "Ausschl\u00fcsse (komma-getrennt)"
    },
    "error_message": {
      "type": "string",
      "title": "Fehlermeldung"
    },
    "summary": {
      "type": "string",
      "title": "Zusammenfassung (JSON)"
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "title": "Gestartet am"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time",
      "title": "Abgeschlossen am"
    },
    "created_by": {
      "type": "string",
      "title": "Erstellt von (E-Mail)"
    },
    "charged_lead_generation": {
      "type": "boolean",
      "title": "Credit verbraucht",
      "default": false
    },
    "top_leads": {
      "type": "string",
      "title": "Top-Leads (JSON)"
    },
    "taxonomy_version": {
      "type": "string",
      "title": "Taxonomie-Version"
    },
    "industry_id": {
      "type": "string",
      "title": "Normalisierte Branchen-ID"
    },
    "selected_target_customer_types": {
      "type": "string",
      "title": "Gew\u00e4hlte Zielkunden (komma-getrennt)"
    },
    "selected_services": {
      "type": "string",
      "title": "Gew\u00e4hlte Dienstleistungen (komma-getrennt)"
    },
    "query_families_used": {
      "type": "string",
      "title": "Genutzte Query-Familien (JSON-Array)"
    },
    "search_queries_used": {
      "type": "string",
      "title": "Alle Suchanfragen mit Metadaten (JSON)"
    },
    "city_mode": {
      "type": "string",
      "title": "Stadt-Modus",
      "enum": [
        "geo_only",
        "keyword_with_city"
      ]
    },
    "search_centers_used": {
      "type": "string",
      "title": "Verwendete Suchzentren (JSON-Array)"
    },
    "zero_result_cause": {
      "type": "string",
      "title": "Ursache bei Null-Ergebnis",
      "enum": [
        "no_queries_built",
        "no_google_results",
        "all_duplicates",
        "no_match_score",
        "all_queries_exhausted",
        "no_geo_coords",
        "taxonomy_profile_missing"
      ]
    },
    "stop_reason": {
      "type": "string",
      "title": "Stopp-Grund (intern)"
    },
    "worker_attempts": {
      "type": "number",
      "title": "Worker-Versuche",
      "default": 0
    },
    "processing_lock_until": {
      "type": "string",
      "format": "date-time",
      "title": "Verarbeitungs-Lock bis",
      "description": "Atomarer Lock: Wenn gesetzt und in der Zukunft, verarbeitet kein anderer Worker diesen Run"
    },
    "processing_by": {
      "type": "string",
      "title": "Verarbeitet von (Worker-Key)",
      "description": "Eindeutiger Worker-Key des aktiven Verarbeiters"
    }
  },
  "required": [
    "organization_id"
  ]
}